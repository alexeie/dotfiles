# Launch Claude Code with a specific settings profile
#
# Arguments:
#   privat [args...]  - Launch with personal profile (direct Anthropic API)
#   tet    [args...]  - Launch with company profile (AWS Bedrock)
#
# Usage:
#   claude-profile privat
#   claude-profile tet
#   claude-profile tet --model sonnet

claude-profile() {
  local claude_dir="$HOME/.claude"
  local privat="$claude_dir/settings-privat.json"
  local tet="$claude_dir/settings-tet.json"

  if [[ $# -eq 0 ]]; then
    echo "Usage: claude-profile [privat|tet] [claude args...]"
    echo "  privat  - Personal Claude (direct Anthropic API)"
    echo "  tet     - Company Claude (AWS Bedrock)"
    return 1
  fi

  local profile="$1"
  shift

  case "$profile" in
    privat)
      claude --settings "$privat" "$@"
      ;;
    tet)
      claude --settings "$tet" "$@"
      ;;
    *)
      echo "Unknown profile: $profile"
      echo "Usage: claude-profile [privat|tet] [claude args...]"
      return 1
      ;;
  esac
}
