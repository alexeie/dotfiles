{
  "hooks": {},
  "enabledPlugins": {
    "ralph-loop@claude-plugins-official": true
  },
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "disableBypassPermissionsMode": "disable",
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
"Bash(git status *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git -C:* diff:*)",
      "Bash(git -C:* log:*)",
      "Bash(git -C:* status:*)",
      "Bash(git -C:* show:*)",
      "Bash(git diff)",
      "Bash(git log *)",
      "Bash(git log)",
      "Bash(git branch *)",
      "Bash(git branch)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git pull *)",
      "Bash(git pull)",
      "Bash(git fetch *)",
      "Bash(git fetch)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git stash *)",
      "Bash(git stash)",
      "Bash(git show *)",
      "Bash(git rev-parse *)",
      "Bash(python *)",
      "Bash(python3 *)",
      "Bash(pip install *)",
      "Bash(pip list)",
      "Bash(pip show *)",
      "Bash(pip freeze)",
      "Bash(pytest *)",
      "Bash(pytest)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(tree *)",
      "Bash(tree)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(diff *)",
      "Bash(jq *)",
      "Bash(sed *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(* --version)",
      "Bash(* --help)",
      "Bash(tofu fmt -recursive*)",
      "Bash(pre-commit run*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(git push)",
      "Bash(rm *)",
      "Bash(chmod *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(ssh *)",
      "Bash(nc *)",
      "Bash(eval *)",
      "Bash(exec *)",
      "Bash(bash -c *)",
      "Bash(sh -c *)",
      "Bash(python -c *)",
      "Bash(rm -rf /*)",
      "Bash(dd *)",
      "Bash(kill *)",
      "Bash(killall *)",
      "Bash(shutdown *)",
      "Bash(reboot *)",
      "Bash(npm publish *)",
      "Bash(npm publish)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/alex/.claude/statusline-command.sh\""
  },
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  }
}