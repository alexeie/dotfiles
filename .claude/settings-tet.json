{
  "env": {
    "AWS_REGION": "eu-north-1",
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "claude-code-eu-north-1",
    "ANTHROPIC_MODEL": "eu.anthropic.claude-sonnet-4-6",
    "ANTHROPIC_SMALL_FAST_MODEL": "eu.anthropic.claude-sonnet-4-6",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://claude-code-otel.tetapps.com",
    "OTEL_RESOURCE_ATTRIBUTES": "department=engineering,team.id=default,                                 cost_center=default,organization=default",
    "OTEL_EXPORTER_OTLP_TIMEOUT": "5000"
  }
  ,
  "statusLine": {
    "type": "command",
    "command": "bash \"/Users/alex/.claude/statusline-command.sh\""
  },
  "includeCoAuthoredBy": false,
  "awsAuthRefresh": "/Users/alex/claude-code-with-bedrock/credential-process --profile claude-code-eu-north-1",
  "otelHeadersHelper": "/Users/alex/claude-code-with-bedrock/otel-helper",
